rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function hasSharedRef(listId) {
      return isAuthenticated() && exists(
        /databases/$(database)/documents/users/$(request.auth.uid)/sharedLists/$(listId)
      );
    }

    // User profile doc
    match /users/{uid} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Pantry items — owner only
    match /users/{uid}/pantry/{pantryItemId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Owned lists — owner can R/W; shared users can read
    match /users/{uid}/lists/{listId} {
      allow read: if isAuthenticated() && (isOwner(uid) || hasSharedRef(listId));
      allow write: if isAuthenticated() && isOwner(uid);
    }

    // Items — owner can R/W; shared users can read items of shared lists
    match /users/{uid}/items/{itemId} {
      allow read: if isAuthenticated() && (
        isOwner(uid) ||
        (
          request.auth != null &&
          hasSharedRef(
            get(/databases/$(database)/documents/users/$(uid)/items/$(itemId)).data.shoppingListId
          )
        )
      );
      allow write: if isAuthenticated() && isOwner(uid);
    }

    // Shared list references for each user
    match /users/{uid}/sharedLists/{listId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Share codes — any authenticated user can read; only create, no overwrite
    match /sharedLists/{code} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Chat messages per list — owner or shared user can R/W
    match /users/{uid}/lists/{listId}/chat_messages/{messageId} {
      allow read, write: if isAuthenticated() && (isOwner(uid) || hasSharedRef(listId));
    }

    // Global chat messages — owner only
    match /users/{uid}/global_chat_messages/{messageId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }
  }
}
