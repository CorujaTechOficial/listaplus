rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function hasSharedRef(listId) {
      return isAuthenticated() && exists(
        /databases/$(database)/documents/users/$(request.auth.uid)/sharedLists/$(listId)
      );
    }

    // User profile doc
    match /users/{uid} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Pantry items — owner only
    match /users/{uid}/pantry/{pantryItemId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Categories — owner only
    match /users/{uid}/categories/{categoryId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Owned lists — owner can R/W; shared users can read
    match /users/{uid}/lists/{listId} {
      allow read: if isAuthenticated() && (isOwner(uid) || hasSharedRef(listId));
      allow write: if isAuthenticated() && isOwner(uid);
    }

    // Items — owner can R/W; shared users can read/write items of shared lists
    match /users/{uid}/items/{itemId} {
      // For read/watch, we allow if owner OR if user has a shared ref to the list this item belongs to.
      // Note: queries must include .where('shoppingListId', '==', listId) for this to work efficiently.
      allow read: if isAuthenticated() && (
        isOwner(uid) || 
        (resource != null && hasSharedRef(resource.data.shoppingListId))
      );
      
      // For write/create/update, we allow if owner OR if user has a shared ref to the target list.
      allow write: if isAuthenticated() && (
        isOwner(uid) || 
        (request.resource != null && hasSharedRef(request.resource.data.shoppingListId)) ||
        (resource != null && hasSharedRef(resource.data.shoppingListId))
      );
    }

    // Shared list references for each user
    match /users/{uid}/sharedLists/{listId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Share codes — any authenticated user can read; only create, no overwrite
    match /sharedLists/{code} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Chat sessions per list — owner or shared user can R/W
    match /users/{uid}/lists/{listId}/chat_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && (isOwner(uid) || hasSharedRef(listId));
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (isOwner(uid) || hasSharedRef(listId));
      }
    }

    // Global chat sessions — owner only
    match /users/{uid}/global_chat_sessions/{sessionId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && isOwner(uid);
      }
    }

    // Legacy chat messages (for migration/compatibility)
    match /users/{uid}/lists/{listId}/chat_messages/{messageId} {
      allow read, write: if isAuthenticated() && (isOwner(uid) || hasSharedRef(listId));
    }
    match /users/{uid}/global_chat_messages/{messageId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Recipes — owner only
    match /users/{uid}/recipes/{recipeId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // Meal plans — owner only
    match /users/{uid}/meal_plans/{planId} {
      allow read, write: if isAuthenticated() && isOwner(uid);
    }

    // App feedback — any authenticated user can create
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
  }
}
