#!/usr/bin/env bash
# =============================================================================
# Pre-commit hook — Shopping List (CorujaTech)
# =============================================================================
# Zero-tolerance: falha em qualquer issue de análise estática
# =============================================================================
set -euo pipefail

echo "━━━ Pre-commit: flutter analyze ━━━"
flutter analyze --fatal-infos 2>&1 && {
  echo "✔  analyzer: nenhum issue encontrado"
} || {
  echo "✘  analyzer encontrou issue(s) — corrija antes de commitar"
  exit 1
}
